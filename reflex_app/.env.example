# Environment variables for Yvynation Reflex App
# Copy to .env and fill with your values

# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json

# Reflex Configuration
REFLEX_ENV=dev
REFLEX_LOG_LEVEL=info
DEBUG=false

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Earth Engine
EE_INITIALIZE_ON_STARTUP=true
EE_USE_SERVICE_ACCOUNT=true

# Database (Reflex default)
REFLEX_DB_URL=sqlite:///reflex.db
